# API Provider: 'grok' or 'kimi'
API_PROVIDER=grok

# For Grok API (x.ai)
GROK_API_KEY=xai-your-grok-api-key-here
GROK_API_URL=https://api.x.ai/v1/chat/completions

# For KIMI API (Moonshot) - alternative
# KIMI_API_KEY=sk-your-kimi-api-key-here
# KIMI_API_URL=https://api.moonshot.cn/v1/chat/completions

# Model selection
# Grok models: grok-2-1212, grok-2-vision-1212, grok-beta
# KIMI models: moonshot-v1-8k, moonshot-v1-32k, moonshot-v1-128k
MODEL_NAME=grok-2-1212
